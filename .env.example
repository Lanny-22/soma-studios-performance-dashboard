# ── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase → Connect → Database → Transaction pooler URI (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres

# Analytics dashboard login (share link + password)
DASHBOARD_PASSWORD=your-password-here

# Download audit email alerts — pick ONE method:

# Option A (easiest): Resend — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=SOMA Analytics <onboarding@resend.dev>   # testing only
# RESEND_FROM=SOMA Analytics <info@somastudiosmt.net>    # after domain verified at resend.com/domains
# DOWNLOAD_ALERT_EMAIL=info@somastudiosmt.net
# Note: onboarding@resend.dev can ONLY send to your Resend signup email until the domain is verified.

# Option B: your own SMTP (e.g. Gmail App Password)
# DOWNLOAD_ALERT_EMAIL=info@somastudiosmt.net
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
